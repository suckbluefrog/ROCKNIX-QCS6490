+++ b/arch/arm64/boot/dts/qcom/sm8650.dtsi
@@ -4924,6 +4924,7 @@ sdhc_2: mmc@8804000 {
 			clock-names = "iface",
 				      "core",
 				      "xo";
+			resets = <&gcc GCC_SDCC2_BCR>;
 
 			interconnects = <&aggre2_noc MASTER_SDCC_2 QCOM_ICC_TAG_ALWAYS
