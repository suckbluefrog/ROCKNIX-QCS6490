--- a/drivers/crypto/rockchip/rk3288_crypto_ahash.c	2026-03-04 10:00:37.518316863 +1300
+++ drivers/crypto/rockchip/rk3288_crypto_ahash.c	2026-03-04 10:03:34.879635045 +1300
@@ -27,17 +27,27 @@
 static bool rk_ahash_need_fallback(struct ahash_request *req)
 {
 	struct scatterlist *sg;
+	int sg_count = 0;
 
 	sg = req->src;
 	while (sg) {
+		if (!sg->length)
+			return true;
 		if (!IS_ALIGNED(sg->offset, sizeof(u32))) {
 			return true;
 		}
 		if (sg->length % 4) {
 			return true;
 		}
+		sg_count++;
 		sg = sg_next(sg);
 	}
+
+	/* Force fallback for multi-fragment scatterlists to prevent
+	 * hash corruption on hardware that processes entries sequentially */
+	if (sg_count > 1)
+		return true;
+
 	return false;
 }
 
