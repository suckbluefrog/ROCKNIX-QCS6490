function gpu_profiling() {
  local sysfs_node
  local profiling_state=${1}
  
  case "${HW_DEVICE}" in
    S922X)
      case "${profiling_state}" in
        "on")
          echo 1 > /sys/bus/platform/drivers/panfrost/[a-f0-9]*.gpu/profiling
        ;;
        "off")
          echo 0 > /sys/bus/platform/drivers/panfrost/[a-f0-9]*.gpu/profiling
        ;;
      esac
    ;;
  esac
}