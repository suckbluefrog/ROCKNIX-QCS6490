+void RAContext::ServerCall(const rc_api_request_t* request,
+                           rc_client_server_callback_t callback,
+                           void* userdata,
+                           rc_client_t*)
+{
+    EnsureHTTPThread();
+
+    RAHttpJob job;
+    job.url = request->url;
+    job.post_data = request->post_data ? request->post_data : "";
+    job.callback = callback;
+    job.userdata = userdata;
