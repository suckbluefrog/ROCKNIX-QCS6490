# Device Features
DEVICE_BATTERY_LED_STATUS="true"
DEVICE_TEMP_SENSOR="/sys/devices/virtual/thermal/thermal_zone0/temp"

# disable legacy headphone script. ALSA UCM does that for us.
# See /usr/share/alsa/ucm2/Rockchip/rk817-sound/HiFi.conf
AUDIO_MANAGEMENT=UCM
EOF
